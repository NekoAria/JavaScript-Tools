{
  "name": "javascript-tools",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "author": "Neko_Aria",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build:bookmarklets": "node scripts/build-bookmarklets.js",
    "build:packages": "node scripts/build-packages.js",
    "format": "stylelint \"packages/**/*.css\" --fix && oxfmt . && prettier --write \"**/*.{md,yml,yaml}\" \"!pnpm-lock.yaml\"",
    "format:check": "stylelint \"packages/**/*.css\" && oxfmt --check . && prettier --check \"**/*.{md,yml,yaml}\" \"!pnpm-lock.yaml\"",
    "lint": "oxlint . && eslint .",
    "lint:fix": "oxlint --fix . && eslint --fix .",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-n": "^18.1.0",
    "eslint-plugin-oxlint": "^1.70.0",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-unicorn": "^65.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "knip": "^6.17.1",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "prettier": "^3.8.4",
    "stylelint": "^17.13.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-order": "^8.1.1",
    "typescript-eslint": "^8.61.1",
    "vite": "catalog:",
    "vite-plugin-monkey": "catalog:"
  }
}
